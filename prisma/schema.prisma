// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
 
// ─── ENUMS ───────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}
 
 enum SocialPlatform {
  GITHUB
  TWITTER
  LINKEDIN
  YOUTUBE
  WEBSITE
  OTHER
}
// ─── USER ────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth
  email          String    @unique
  password       String  
  // Profile
  username     String 
  age          Int?
  gender       Gender? 
  photoUrl     String? @default("https://img.freepik.com/premium-vector/default-avatar-profile-icon-social-media-user-image-gray-avatar-icon-blank-profile-silhouette-vector-illustration_561158-3383.jpg?semt=ais_incoming&w=740&q=80")
  profile   Profile?
  projects  Project[]
  socials   SocialLink[]

  followers  Follow[] @relation("followers")
  following  Follow[] @relation("following")
  @@index([createdAt])
  @@map("users")
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String? @db.VarChar(500)
  yearsOfExp Int? 
  portfolio String?
  skills UserSkill[]
  @@map("profiles")
}

model Skill {
  id String @id @default(uuid())
  name String @unique
  skills UserSkill?
  slug String @unique 
}

model UserSkill {
  profileId String
  skillId String @unique
  profile Profile @relation(fields:[profileId],references:[id], onDelete: Cascade)
  skill Skill @relation(fields:[skillId],references:[id], onDelete: Cascade)
  @@id([profileId,skillId])
}

model Project {
  id          String   @id @default(uuid())
  createdAt  DateTime @default(now())
  userId      String
  title       String
  description String
  githubUrl   String?
  liveUrl     String?
  techStack String[]
  featured Boolean @default(false)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SocialLink {
  id     String @id @default(uuid())
  userId String
  type   SocialPlatform
  url    String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id           String @id @default(uuid())
  createdAt DateTime @default(now())
  followerId   String
  followingId  String
  follower  User @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)
  @@unique([followerId, followingId])
}
